generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Platform {
  YOUTUBE
  TIKTOK
  INSTAGRAM
  XIAOHONGSHU
  DOUYIN
}

enum VideoFormat {
  AI_GENERATED
  ORIGINAL
  MONTAGE
  COMPILATION
  HIGHLIGHT
  MEME_TEMPLATE
  STORY
  IMAGE_SLIDE
  UNDEFINED
}

model Folder {
  id        String    @id @default(cuid())
  name      String    @unique
  sortOrder Int       @default(0)
  isSeeded  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  channels  Channel[]
  hashtags  Hashtag[]
}

model Hashtag {
  id        String    @id @default(cuid())
  platform  Platform
  tag       String                                            // 저장할 때 # 떼고 소문자
  folderId  String?
  folder    Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@unique([platform, tag])
  @@index([folderId])
}

model Channel {
  id              String    @id @default(cuid())
  platform        Platform
  externalId      String
  handle          String?
  displayName     String?
  thumbnailUrl    String?
  subscriberCount Int?
  totalViewCount  BigInt?
  folderId        String
  folder          Folder    @relation(fields: [folderId], references: [id])
  videos          Video[]
  isActive        Boolean   @default(true)
  addedAt         DateTime  @default(now())
  lastScrapedAt   DateTime?

  @@unique([platform, externalId])
  @@index([folderId])
}

model Video {
  id              String   @id @default(cuid())
  channelId       String
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  platform        Platform
  externalId      String
  url             String
  caption         String?
  thumbnailUrl    String?
  viewCount       BigInt   @default(0)
  likeCount       Int?
  commentCount    Int?
  shareCount      Int?
  durationSeconds Int?
  isShorts        Boolean?
  publishedAt     DateTime
  fetchedAt       DateTime @default(now())
  viralScore      Float?
  format          VideoFormat?
  formatLockedBy  String?         // 'auto' | 'user' — user 락이면 자동 추론이 덮어쓰지 않음
  sourceHashtag   String?         // null이면 일반(채널) 수집, 값 있으면 그 해시태그로 발견
  isStarred       Boolean         @default(false)

  @@unique([platform, externalId])
  @@index([sourceHashtag])
  @@index([channelId, publishedAt])
  @@index([viralScore])
  @@index([publishedAt])
  @@index([isStarred])
}

model YoutubeApiKey {
  id              String    @id @default(cuid())
  label           String
  apiKey          String    @unique
  isActive        Boolean   @default(true)
  dailyQuotaLimit Int       @default(10000)
  usedToday       Int       @default(0)
  lastUsedAt      DateTime?
  exhaustedAt     DateTime?
  resetAt         DateTime?
  failCount       Int       @default(0)
  lastError       String?
  createdAt       DateTime  @default(now())
}

model Credential {
  id          String   @id @default(cuid())
  service     String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model ScrapeRun {
  id         String    @id @default(cuid())
  channelId  String?
  platform   Platform
  status     String
  itemsCount Int       @default(0)
  costUsd    Float?
  quotaUsed  Int?
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([channelId])
  @@index([startedAt])
}

/// YouTube 트렌딩 mostPopular 스냅샷 (KR only, 시간당 누적).
/// 캡처 시점 별로 영상 메타·통계 저장. 같은 videoId 가 시간마다 반복 저장됨.
/// 최근 N시간 누적해서 쇼츠 100+개 보장하는 용도.
model TrendingSnapshot {
  id              String   @id @default(cuid())
  region          String   // 'KR' 등
  videoId         String   // YouTube 11자
  title           String
  channelId       String
  channelName     String
  thumbnailUrl    String?
  viewCount       BigInt
  likeCount       BigInt?
  commentCount    BigInt?
  durationSeconds Int
  isShorts        Boolean
  publishedAt     DateTime
  capturedAt      DateTime @default(now())

  @@index([region, capturedAt])
  @@index([region, isShorts, capturedAt])
  @@index([videoId])
}

/// 트렌딩 스냅샷 cron 설정 (싱글톤 행, id='default').
model TrendingSettings {
  id            String   @id @default("default")
  enabled       Boolean  @default(true)
  intervalHours Int      @default(4)
  lastRunAt     DateTime?
  lastError     String?
  updatedAt     DateTime @updatedAt
}

/// OpenAI OAuth (Codex CLI 방식 우회 — Sign in with ChatGPT, device flow).
/// 싱글톤 (id='default'). ⚠️ TOS 회색지대 — OpenAI가 차단할 가능성 있음.
model OpenAIOAuth {
  id           String   @id @default("default")
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  accountEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
