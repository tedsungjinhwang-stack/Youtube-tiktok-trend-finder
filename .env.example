# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth whitelist (only this email can log in)
OWNER_EMAIL=your@gmail.com

# Apify (TikTok / Instagram scraping)
APIFY_API_TOKEN=

# OpenClaw API key (random string you generate)
OPENCLAW_API_KEY=

# Cron secret (Vercel Cron Authorization header)
CRON_SECRET=

# YouTube API keys are managed in DB via /settings/youtube-keys (not env)
