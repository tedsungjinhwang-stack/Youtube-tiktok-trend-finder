{
    "manifest_version": 3,
    "name": "Threads Media Downloader",
    "version": "1.1.0",
    "description": "Download images and videos from Threads with automatic quality enhancement.",
    "permissions": [
        "downloads"
    ],
    "host_permissions": [
        "https://www.threads.com/*",
        "https://www.threads.net/*",
        "https://*.cdninstagram.com/*",
        "https://*.fbcdn.net/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.threads.com/*",
                "https://www.threads.net/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
